{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "packages/core/src/cli.ts",
    "packages/core/src/server.ts",
    "packages/core/src/index.ts",
    "apps/site/src/routes/**/*.svelte",
    "apps/site/src/lib/index.ts"
  ],
  "ignorePatterns": [
    "dist/**",
    "build/**",
    ".svelte-kit/**",
    "**/*.d.ts",
    "packages/core/src/processor/**",
    "packages/core/src/scraper/**",
    "apps/site/src/components/**",
    "apps/site/src/lib/components/**",
    "**/node_modules/**",
    "**/__tests__/**",
    "**/*.test.{ts,js}",
    "**/*.spec.{ts,js}",
    "coverage/**",
    ".next/**",
    "out/**",
    "**/.fallow/**",
    ".github/**",
    "docs-mcp/**",
    "research/**"
  ],
  "ignoreDependencies": ["@types/**"],
  "ignoreExportsUsedInFile": true,
  "publicPackages": ["docshark", "docshark-site"],
  "dynamicallyLoaded": ["packages/core/src/tools/**/*.ts"],
  "duplicates": {
    "mode": "mild",
    "minTokens": 50,
    "minLines": 5,
    "minOccurrences": 3,
    "ignore": [
      "packages/core/src/processor/**",
      "packages/core/src/scraper/**",
      "apps/site/src/components/**",
      "apps/site/src/lib/components/**"
    ]
  },
  "health": {
    "maxCyclomatic": 15,
    "maxCognitive": 12,
    "maxCrap": 25,
    "ignore": [
      "packages/core/src/processor/extractor.ts",
      "packages/core/src/search/**",
      "apps/site/src/routes/**"
    ]
  },
  "rules": {
    "unused-files": "error",
    "unused-exports": "warn",
    "unused-types": "warn",
    "private-type-leaks": "off",
    "unused-dependencies": "error",
    "unused-dev-dependencies": "warn",
    "unused-optional-dependencies": "warn",
    "unused-enum-members": "warn",
    "unused-class-members": "warn",
    "unresolved-imports": "error",
    "unlisted-dependencies": "error",
    "duplicate-exports": "warn",
    "circular-dependencies": "error",
    "boundary-violation": "warn",
    "type-only-dependencies": "error",
    "test-only-dependencies": "warn",
    "coverage-gaps": "off",
    "stale-suppressions": "warn"
  }
}
