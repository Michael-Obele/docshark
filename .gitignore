## Node.js common ignores

# Dependencies
node_modules/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by coverage tools
coverage/
*.lcov
.nyc_output/

# Build outputs
dist/
build/
out/
.next/
.vercel/
.netlify/

# Local env files
.env
.env.*

# Parcel, Next & other caches
.cache/
.parcel-cache/

# Optional npm cache
.npm

# Optional eslint/stylelint caches
.eslintcache
.stylelintcache

# IDEs and editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# OS files
.DS_Store
Thumbs.db

# Misc
*.tgz
*.gz
